' Gambas class file

Public Sub Form_Open()

  Dim texto As String
  Dim linea As String
  Dim archivo As String

  archivo = FMain.rutaFILES & "/gbTeXv-" & FMain.BaseName & ".log"
  texto = File.Load(archivo)

  TextArea1.Text = ""

  For Each linea In Split(texto, gb.NewLine)
    ' linea = Conv(linea, "latin1", "utf-8")
    ' Elimina los espacios en blanco al principio y al final de la línea
    linea = Trim(linea)
    TextArea1.Text &= linea & gb.NewLine
  Next

  Form_Contador.Title = "Estadística del archivo"

End

Public Sub btnCerrar_Click()

  Me.Close

End
