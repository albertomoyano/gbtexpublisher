# Gambas Form File 3.0

{ Form Form
  Move(0,0,950,153)
  #Scaled = False
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  Spacing = True
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(9,9,800,36)
    NoTabFocus = True
    { lbl Label
      Move(207,0,333,36)
      Font = Font["Bold"]
      Expand = True
      Alignment = Align.Center
      Text = ("Se creará un directorio oculto (.respaldogbTeX) en el destino seleccionado")
    }
  }
  { HBox2 HBox
    Move(9,63,800,36)
    NoTabFocus = True
    { Label1 Label
      Move(9,0,162,36)
      NoTabFocus = True
      Alignment = Align.Right
      Text = ("Seleccionar destino  ")
    }
    { btnSeleccionarDir Button
      Move(297,0,36,36)
      NoTabFocus = True
      Picture = Picture["iconos/search.svg"]
    }
    { txtDestino TextBox
      Move(369,0,216,36)
      #Translate = False
      Background = Color.Background
      NoTabFocus = True
      Expand = True
      ReadOnly = True
    }
  }
  { HBox7 HBox
    Move(9,108,783,36)
    { Spring1 Spring
      Move(135,0,117,36)
    }
    { btnListo Button
      Move(351,0,160,36)
      Visible = False
      Background = &H8BE06F
      NoTabFocus = True
      Text = ("Confirmar")
    }
    { Separator1 Separator
      Move(531,0,9,36)
      Foreground = Color.Transparent
    }
    { btnSalir Button
      Move(558,0,160,36)
      Font = Font["Bold"]
      Background = &HE00000
      Foreground = Color.White
      NoTabFocus = True
      Text = ("Cerrar")
    }
  }
}
