# Gambas Form File 3.0

{ Form Form
  Move(0,0,950,153)
  #Scaled = False
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  Spacing = True
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(9,9,800,36)
    NoTabFocus = True
    { lbl Label
      Move(207,0,333,36)
      Expand = True
      Alignment = Align.Center
      Text = ("Se creará un directorio oculto (.respaldogbTeX) en el destino seleccionado")
    }
  }
  { HBox2 HBox
    Move(9,63,800,36)
    NoTabFocus = True
    { Label1 Label
      Move(9,0,153,40)
      NoTabFocus = True
      AutoResize = True
      Alignment = Align.Right
      Text = ("     Destino  ")
    }
    { txtDestino TextBox
      Move(369,0,216,40)
      #Translate = False
      Foreground = Color.Blue
      NoTabFocus = True
      Expand = True
      ReadOnly = True
      Placeholder = "Seleccione un destino"
    }
    { btnSeleccionarDir Button
      Move(594,0,160,40)
      NoTabFocus = True
      Text = ("Seleccionar")
      Picture = Picture["iconos/document-orange.svg"]
    }
  }
  { HBox7 HBox
    Move(9,108,783,36)
    { Spring1 Spring
      Move(135,0,117,36)
    }
    { btnListo Button
      Move(351,0,160,40)
      NoTabFocus = True
      Text = ("Listo")
      Picture = Picture["iconos/emblem-default.svg"]
    }
    { btnSalir Button
      Move(558,0,160,40)
      NoTabFocus = True
      Text = ("Cerrar")
      Picture = Picture["iconos/salir.svg"]
    }
  }
}
