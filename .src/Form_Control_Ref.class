' Gambas class file

Private conector As Connection
Private Contenido1 As Result
Private Contenido2 As Result
Private Busqueda1 As Result

Public Sub Form_Open()

  ' Crear una nueva conexión
  conector = New Connection

  ' Configurar los parámetros de conexión
  conector.Type = "sqlite"
  conector.Host = User.Home &/ ".gbtexpublisher"
  conector.Name = "db_tex.sqlite"

  ' Intentar abrir la conexión
  Try conector.Open()

  If Error Then
    conector = Null
    Message.Error("Error al intentar conectarse con la base de datos. Asegúrese de que el archivo de la base de datos <strong>db_tex.sqlite</strong> se encuentra disponible. El mismo debe encontrarse en " & User.Home &/ ".gbtexpublisher")
  Else

    cbRELATEDTYPE1.Add("")
    cbRELATEDTYPE1.Add("reprintof")
    cbRELATEDTYPE1.Add("translationof")
    cbRELATEDTYPE1.Add("translatedas")
    cbRELATEDTYPE1.Add("multivolume")

    cbRELATEDTYPE2.Add("")
    cbRELATEDTYPE2.Add("reprintof")
    cbRELATEDTYPE2.Add("translationof")
    cbRELATEDTYPE2.Add("translatedas")
    cbRELATEDTYPE2.Add("multivolume")

    Mostrar_Lista()
    Mostrar_Lista2()
  Endif

End

