Public Sub Form_Close()

  ' Desconectar la base de datos
  If conector Then
    conector.Close()
    conector = Null
  Endif

  Me.Close()

End

Public Sub btnCerrar_Click()

  ' Desconectar la base de datos
  If conector Then
    conector.Close()
    conector = Null
  Endif

  Me.Close()

End

