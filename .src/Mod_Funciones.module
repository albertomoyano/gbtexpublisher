' Función para mostrar datos en un GridView
Public Sub Mostrar_ListaBIB(grid As GridView)

  Dim i As Integer
  Dim Contenido As Result

  ' Limpiar el GridView
  grid.Clear()

  ' Configurar las columnas
  Configurar_Columnas(grid)

  ' Ejecutar la consulta SQL
  Contenido = FMain.meConn.Exec("SELECT * FROM bibtex ORDER BY id DESC")

  ' Asignar la cantidad de filas según los datos
  grid.Rows.Count = Contenido.Count

  ' Recorrer el resultado de la consulta y llenar el GridView
  For i = 0 To Contenido.Count - 1
    grid[i, 0].Text = Contenido!id
    grid[i, 1].Text = Contenido!tipoEntrada
    grid[i, 2].Text = Contenido!citationKey
    grid[i, 3].Text = Contenido!keywords
    grid[i, 4].Text = Contenido!author
    grid[i, 5].Text = Contenido!bookAuthor
    grid[i, 6].Text = Contenido!editor
    grid[i, 7].Text = Contenido!editorA
    grid[i, 8].Text = Contenido!editorB
    grid[i, 9].Text = Contenido!editorC
    grid[i, 10].Text = Contenido!afterword
    grid[i, 11].Text = Contenido!commentator
    grid[i, 12].Text = Contenido!translator
    grid[i, 13].Text = Contenido!holder
    grid[i, 14].Text = Contenido!shortAuthor
    grid[i, 15].Text = Contenido!editorType
    grid[i, 16].Text = Contenido!editorAtype
    grid[i, 17].Text = Contenido!editorBtype
    grid[i, 18].Text = Contenido!editorCtype
    grid[i, 19].Text = Contenido!foreword
    grid[i, 20].Text = Contenido!introduction
    grid[i, 21].Text = Contenido!annotator
    grid[i, 22].Text = Contenido!gender
    grid[i, 23].Text = Contenido!nameAddOn
    grid[i, 24].Text = Contenido!title
    grid[i, 25].Text = Contenido!shortTitle
