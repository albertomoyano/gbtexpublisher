Public Sub VerificarPorcentajeEnTexto(TextoOriginal As String) As String

  Dim nuevoTexto As String

  nuevoTexto = TextoOriginal

  ' hacemos reemplazos de seguridad
  nuevoTexto = Replace(nuevoTexto, "%", "\\%")
  nuevoTexto = Replace(nuevoTexto, "´", "'")
  nuevoTexto = Replace(nuevoTexto, "’", "'")

  ' Devolvemos el texto modificado
  Return nuevoTexto

End

Public Sub AsignarValoresDesdeGridView(GridV As GridView, Row As Integer, Columnas As Integer[], TextBoxes As TextBox[], ComboBoxes As ComboBox[], TextAreas As TextArea[], TextAreasColumnas As Integer[], ComboBoxesColumnas As Integer[])

  Dim Columna As Integer
  Dim Valor As String

  ' Asignar valores a TextBoxes
  For i As Integer = 0 To TextBoxes.Length - 1
    If i < Columnas.Length Then
      Columna = Columnas[i] ' Asignar el índice de la columna
      Valor = GridV[Row, Columna].Text ' Obtener el valor de la celda
      TextBoxes[i].Text = Valor
    End If
  Next

  ' Asignar valores a ComboBoxes
  For i As Integer = 0 To ComboBoxes.Length - 1
    If i < ComboBoxesColumnas.Length Then
      Columna = ComboBoxesColumnas[i] ' Usar el índice específico para TextAreas
      Valor = GridV[Row, Columna].Text ' Obtener el valor de la celda
      ' Forzar la conversión a cadena
      Valor = CStr(Valor)
      ' Asignar el valor al TextArea
      ComboBoxes[i].Text = Valor
    End If
  Next

  ' Asignar valores a TextAreas
  For i As Integer = 0 To TextAreas.Length - 1
    If i < TextAreasColumnas.Length Then
      Columna = TextAreasColumnas[i] ' Usar el índice específico para TextAreas
      Valor = GridV[Row, Columna].Text ' Obtener el valor de la celda
      ' Forzar la conversión a cadena
      Valor = CStr(Valor)
      ' Asignar el valor al TextArea
      TextAreas[i].Text = Valor
    End If
  Next

End

