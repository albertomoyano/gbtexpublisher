' Función para llenar el GridView con datos
Public Sub Mostrar_ListaBibActual(grid As GridView)

  Dim i As Integer
  Dim Contenido As Result
  Dim nombreArchivo As String = File.BaseName(FMain.TextBox1.Text)
  ' Limpiar el GridView
  grid.Clear()

  ' Configurar las columnas
  Configurar_Columnas(grid)

  ' Ejecutar la consulta SQL
  Contenido = FMain.meConn.Exec("SELECT * FROM bibtex WHERE keywords LIKE '%" & nombreArchivo & "%' ORDER BY id DESC;")'LIKE

  ' Asignar la cantidad de filas según los datos
  grid.Rows.Count = Contenido.Count

  ' Recorrer el resultado de la consulta y llenar el GridView
  For i = 0 To Contenido.Count - 1
    grid[i, 0].Text = Contenido!id
    grid[i, 1].Text = Contenido!tipoEntrada
    grid[i, 2].Text = Contenido!citationKey
    grid[i, 3].Text = Contenido!keywords
    grid[i, 4].Text = Contenido!author
    grid[i, 5].Text = Contenido!bookAuthor
    grid[i, 6].Text = Contenido!editor
