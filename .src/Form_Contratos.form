# Gambas Form File 3.0

{ Form Form
  Move(0,0,960,640)
  #Scaled = False
  Text = ("Contratos de edición")
  Resizable = False
  Arrangement = Arrange.Vertical
  Spacing = True
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(9,9,927,36)
    { tbNuevo Button
      Move(0,0,36,36)
      NoTabFocus = True
      ToolTip = ("Agregar entrada")
      Picture = Picture["iconos/+nuevo.svg"]
    }
    { tbBorrar Button
      Move(36,0,36,36)
      NoTabFocus = True
      ToolTip = ("Eliminar entrada")
      Picture = Picture["iconos/borrar.svg"]
    }
    { btnGuardar Button
      Move(72,0,36,36)
      NoTabFocus = True
      ToolTip = ("Guardar entrada")
      Picture = Picture["iconos/guardar.svg"]
    }
    { btnGuardarMod Button
      Move(108,0,36,36)
      NoTabFocus = True
      ToolTip = ("Guardar cambios")
      Picture = Picture["iconos/guardarComo.svg"]
    }
    { !btnRefresh Button
      Move(144,0,36,36)
      #Public = True
      Visible = False
      NoTabFocus = True
      ToolTip = ("Refrescar datos")
      Picture = Picture["iconos/refrescar.svg"]
    }
    { BtnExportarDOCX Button
      Move(180,0,36,36)
      NoTabFocus = True
      ToolTip = ("Exportar la nota como archivo de texto plano")
      Picture = Picture["iconos/ms-office.svg"]
    }
    { BtnExportarPDF Button
      Move(216,0,36,36)
      NoTabFocus = True
      ToolTip = ("Exportar la nota como archivo de texto plano")
      Picture = Picture["iconos/acroread.svg"]
    }
    { txtBuscarContrato TextBox
      Move(252,0,290,40)
    }
    { BtnBuscar Button
      Move(590,0,36,36)
      NoTabFocus = True
      ToolTip = ("Buscar en toda la base de datos")
      Picture = Picture["iconos/search.svg"]
    }
    { Spring1 Spring
      Move(640,0,36,40)
    }
    { btnCerrar ToolButton
      Move(702,0,160,36)
      Background = &HE00000
      Foreground = Color.White
      NoTabFocus = True
      ToolTip = ("Cerrar la ventana")
      Text = ("Cerrar")
      Border = True
    }
  }
  { tblContratos TableView
