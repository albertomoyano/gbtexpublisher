  btnGuardarCambios.Enabled = False
  btnAgregarCitationKey.Enabled = False
  btnGuardarIGUAL.Enabled = False

  LimpiarCamposBIB() ' Limpiamos los campos
  VListaBIB.Clear
  Mostrar_ListaBIB()

End

Public Sub BtnBuscarEtiquetas_Click()'buscar etiquetas

  Dim rowIndex As Integer

  If txtETIQ.Text = "" Then
    Message.Warning("Debe introducir contenido a buscar.")
    Return
  Endif

  Busqueda = Conn.Exec("SELECT * FROM  bibtex WHERE etiquetas=&1 COLLATE NOCASE", txtETIQ.Text)

  ' Limpia el Grid antes de mostrar los resultados de la búsqueda
