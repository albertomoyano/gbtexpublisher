Public Sub UpdateMenu()

  Dim MenuItem As Menu
  Dim sFileName As String

  mnu1LastFiles.Children.Clear
  If MS.ShortMatrix.Count = 0 Then
    mnu1LastFiles.Visible = False
  Else
    For Each sFileName In MS.ShortMatrix
      MenuItem = New Menu(mnu1LastFiles) As "mnuLast"
      MenuItem.Text = sFileName
    Next
  End If

End

