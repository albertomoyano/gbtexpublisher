Public Sub Form_Open()

  Mod_Conn.conectar()'me conecto a las 2 bases de datos, es temporal hasta resolver la conexión con mysql
  Mod_Conn.Conectar2()

  pBash = TerminalView1.Exec(["/usr/bin/bash"])
  TerminalView1.SetFocus()

  'configuración del ToDo
  Splitter2.Layout = [3, 1]
  txtTAREAS.Visible = False
  Mostrar_Lista_Tareas

  MS.Init()
  MS.GetLastListFromSettings()
  UpdateMenu()

  rutaFILES = File.Dir(TextBox1.Text) &/ "files"
  rutaCORRECCIONES = File.Dir(TextBox1.Text) &/ "correcciones"
  rutaMEDIA = File.Dir(TextBox1.Text) &/ "media"
  rutaORIGINALES = File.Dir(TextBox1.Text) &/ "originales"
  rutaTAPA = File.Dir(TextBox1.Text) &/ "tapa"
  rutaCATALOGO = File.Dir(TextBox1.Text) &/ "catalogo"
  rutaARTCAP = File.Dir(TextBox1.Text) &/ "artcap"
  BaseName = File.BaseName(TextBox1.Text)

  ' controlamos que la aplicación no esté en ejecución
  Dim s As String
  Exec ["pgrep", "-fla", Application.Name] Wait To s
  If Split(Trim$(s), gb.NewLine, "", True).Count > 1 Then
    Message.Warning(Application.name & (" ya se está ejecutando"))
    Quit
  Endif

  Fmain.Title = Application.Title & " (versión en desarrollo " & Application.Version & ")"

  Dim mtmp As Menu
  Dim file As String

  For Each file In Dir(rutaScriptsExternos, "*.py").Sort()
    mtmp = New Menu(Menu76) As "obs"
    mtmp.caption = File
  Next

  ' comienza glosario
  ' cargamos los datos del combobox
  cbTYPEentradaGlo.Add("sigla")
  cbTYPEentradaGlo.Add("glosario")
  BtnEliminarGlo.Enabled = False
  BtnRefrescarGlo.Enabled = False
  btnGuardarGlo.Enabled = False
  btnGuardarCambiosGlo.Enabled = False
  Mostrar_ListaGLO

  ' comienza metadatos
  cmbTypePub.Add("research-article")
  cmbTypePub.Add("review-article")
  cmbTypePub.Add("editorial")
  cmbTypePub.Add("case-report")
  cmbTypePub.Add("letter")
  cmbTypePub.Add("commentary")
  cmbTypePub.Add("correction")
  txt40_pdfmetalang.Add("es")
  txt40_pdfmetalang.Add("pt")
  txt40_pdfmetalang.Add("en")
  txt40_pdfmetalang.Add("fr")
  txt40_pdfmetalang.Add("de")
  txt40_pdfmetalang.Add("it")
  txt54_idiomaorig.Add("")
  txt54_idiomaorig.Add("es")
  txt54_idiomaorig.Add("pt")
  txt54_idiomaorig.Add("en")
  txt54_idiomaorig.Add("fr")
  txt54_idiomaorig.Add("de")
  txt54_idiomaorig.Add("it")
  cbLang.Add("Español de España: es-ES")
  cbLang.Add("Portugués de Brasil: pt-BR")
  cbLang.Add("Inglés de Estados Unidos: en-US")
  cbLang.Add("Francés de Francia: fr-FR")
  cbLang.Add("Alemán de Alemania: de-DE")
  cbLang.Add("Italiano: it-IT")
  cbLang.Add("Japonés: ja-JP")
  cbLang.Add("Chino simplificado: zh-Hans")
  txt15_pdfcopyright.Add("Copyright")
  If txt16_pdflicenseurl.Text = "" Then
    txt16_pdflicenseurl.Text = "https://es.wikipedia.org/wiki/Copyright"
  Endif
  txt15_pdfcopyright.Add("CC0 1.0 Universal")
  txt15_pdfcopyright.Add("CC BY 4.0 Attribution 4.0 International")
  txt15_pdfcopyright.Add("CC BY-SA 4.0 Attribution-ShareAlike 4.0 International")
  txt15_pdfcopyright.Add("CC BY-ND 4.0 Attribution-NoDerivatives 4.0 International")
  txt15_pdfcopyright.Add("CC BY-NC 4.0 Attribution-NonCommercial 4.0 International")
  txt15_pdfcopyright.Add("CC BY-NC-SA 4.0 Attribution-NonCommercial-ShareAlike 4.0 International")
  txt15_pdfcopyright.Add("CC BY-NC-ND 4.0 Attribution-NonCommercial-NoDerivatives 4.0 International")
  txt15_pdfcopyright.Add("GNU General Public License")
  txt15_pdfcopyright.Add("Licencia MIT")
  txt15_pdfcopyright.Add("Licencia BSD")
  txt15_pdfcopyright.Add("Otra")
  cmbType.Add("Text")
  cmbType.Add("Software")
  cmbType.Add("Sound")
  cmbType.Add("Dataset")
  cmbType.Add("InteractiveResource")
  cbPDFrendition.Add("default")
  cbPDFrendition.Add("draft")
  cbPDFrendition.Add("low-res")
  cbPDFrendition.Add("proof")
  cbPDFrendition.Add("screen")
  cbPDFrendition.Add("thumbnail")
  cbPubType.Add("book")
  cbPubType.Add("journal")
  cbPubType.Add("magazine")
  cbPubType.Add("manual")
  cbPubType.Add("report")
  cbPubType.Add("whitepaper")
  cbPubStatus.Add("Author's Original: AO")
  cbPubStatus.Add("Submitted Manuscript Under Review: SMUR")
  cbPubStatus.Add("Accepted Manuscript: AM")
  cbPubStatus.Add("Proof: P")
  cbPubStatus.Add("Version Of Record: VoR")
  cbPubStatus.Add("Corrected Version Of Record: CVoR")
  cbPubStatus.Add("Enhanced Version Of Record: EVoR")
  cbPDFx.Add("pdf/A")
  cbPDFx.Add("pdf/x-1a:2001")
  cbPDFx.Add("pdf/x-1a:2003")
  cbPDFx.Add("pdf/x-3:2002")
  cbPDFx.Add("pdf/x-3:2003")
  cbPDFx.Add("pdf/x-4")
  cbPDFx.Add("pdf/x-4p")
  cbPDFx.Add("pdf/x-5g")
  cbPDFx.Add("pdf/x-5n")
  cbPDFx.Add("pdf/x-5pg")

  txt89_binding.Add("")
  txt89_binding.Add("Encolado")
  txt89_binding.Add("Everflex")
  txt89_binding.Add("Cosido a hilo")
  txt89_binding.Add("Anillado")
  txt89_binding.Add("Abrochado")

  ' comienza bibtex
  BtnEliminarBib.Enabled = False
  btnGuardar.Enabled = False
  btnGuardarCambios.Enabled = False
  Dim editorType As String[] = ["", "editor", "compiler", "direction", "founder", "continuator", "redactor", "reviser", "collaborator", "cordinator"]
  Dim pubState As String[] = ["", "inpreparation", "submitted", "forthcoming", "inpress", "prepublished"]
  Dim thesis As String[] = ["", "@thesis (seleccionar)", "tifthesis", "mathesis", "phdthesis", "candthesis", "ingenieriathesis", "magisterthesis", "gradothesis", "licenciaturathesis", "especialthesis", "posgradothesis", " ", "@manual (seleccionar)", " ", "@patent (seleccionar)", " ", "@report (seleccionar)"]
  Dim relatedType As String[] = ["", "reprintof", "translationof", "translatedas", "multivolume"]
  Dim tipoEntrada As String[] = ["", "article", "incollection", "book", "thesis", "online", "inproceedings", "mvbook", "inbook", "bookinbook", "suppbook", "booklet", "collection", "mvcollection", "suppcollection", "manual", "misc", "patent", "periodical", "suppperiodical", "proceedings", "mvproceedings", "reference", "mvreference", "inreference", "report", "set", "unpublished", "xdata", "movie"]
  Dim hyphenation As String[] = ["", "spanish", "portuguese", "french", "italian", "german", "english", "latin", "greek", "chinese", "norwegian", "swedish", "danish", "dutch", "japanese", "romanian", "armenian", "korean", "russian", "latin", "czech"]

  'PREPARAMOS LOS COMBOBOX
  cbEDITORTYPE.List = editorType
  cbEDITORTYPE.Text = cbEDITORTYPE[0].Text

  cbEDITORTYPEa.List = editorType
  cbEDITORTYPEa.Text = cbEDITORTYPEa[0].Text

  cbEDITORTYPEb.List = editorType
  cbEDITORTYPEb.Text = cbEDITORTYPEb[0].Text

  cbEDITORTYPEc.List = editorType
  cbEDITORTYPEc.Text = cbEDITORTYPEc[0].Text

  cbPUBSTATE.List = pubState
  cbPUBSTATE.Text = cbPUBSTATE[0].Text

  cbType.List = thesis
  cbType.Text = cbType[0].Text

  cbRELATEDTYPE.List = relatedType
  cbRELATEDTYPE.Text = cbRELATEDTYPE[0].Text

  cbTYPEentrada.List = tipoEntrada
  cbTYPEentrada.Text = cbTYPEentrada[0].Text

  cbLANGUAGE.List = hyphenation
  cbLANGUAGE.Text = cbLANGUAGE[0].Text

  cbLANGUAGEID.List = hyphenation
  cbLANGUAGEID.Text = cbLANGUAGEID[0].Text

  Mostrar_ListaBIB()
  TotalEntradas()

  ' Verifica si el TextBox1 tiene una ruta válida
  If Not IsNull(TextBox1.Text) And TextBox1.Text <> "" Then
    ' Hacemos el seguimiento del DirChooser
    Watcher.Path = File.Dir(TextBox1.Text) ' Establece la ruta del directorio a monitorear
    Watcher.AddMask("create,delete") ' Monitorea eventos de creación y eliminación
    Watcher.Start
    ' Inicializa la lista de archivos
    prevFiles = DirViewRuta.Files
  End If

End

Public Sub Form_Close()

  Dim fecha As String

  fecha = Format(Date(), "dd-mm-yyyy") ' Obtener la fecha actual

  If Message.Question("¿Desea cerrar la aplicación?\n\nAl cerrar, esta acción realizará una copia de respaldo de la base de datos con el nombre <b>" & fecha & "-" & "db_tex.sqlite</b> y de <b>" & fecha & "-" & "conn_serv.sqlite</b>.", "Aceptar", "Cancelar") = 1 Then
    Conn.Close

    'hacemos una copia de respaldo de la base de datos
    Shell "cp " & rutaApp &/ "db_tex.sqlite" & " " & rutaAppR &/ fecha & "-" & "db_tex.sqlite"
    Wait 0.1
    Shell "cp " & rutaApp &/ "conn_serv.sqlite" & " " & rutaAppR &/ fecha & "-" & "conn_serv.sqlite"
    Wait 0.1

    'guardamos el último archivo abierto
    MS.SetLastListToSettings()
    Try pBash.Close
    Try fFile.Close
    Quit
  Else
    Stop Event
  Endif

End

Public Sub Borrar_Aux()

  TerminalView1.Input("cd " & File.Dir(TextBox1.Text) & "\n" & "rm *.bcf-SAVE-ERROR html5-*_html.tex *.bbl-SAVE-ERROR html5-*.tex *.css *.lwarpmkconf *.sidetoc *.conf *.cut *.upa *.upb *.bib.backup *.ndx *.ps *.tex.backup *.bib *.csv *.published *.dat *.txt *.pdf *.bib.sav *.xml *.html *.xhtml *.opf *.xref *.ncx *.tmp *.4ct *.4tc *.4of *.4ot *.4os *.4oy *.4oo *.4og *.lg *.idv *.acn *.acr *.alg *.glg *.gls *.ist *.bak *.log *.aux *.dvi *.lof *.lot *.bit *.idx *.glo *.bbl *.bcf *.ilg *.toc *.ind *.out *.blg *.fdb_latexmk *.fls *.run.xml *.ida *.idn *.inn *.synctex.gz *.xdy *.opf *.epub *.mobi *.ent *.cfg *.lua *.mk4 *.png *.jpg *.svg" & "\n" & "clear" & "\n") 'desde la raiz al directorio padre
  Wait 0.2

  TerminalView1.SetFocus()

End

'ejecutamos el evento click del observador
Public Sub obs_click()

  TerminalView1.Input("clear" & "\n")
  TerminalView1.Input("python3 " & rutaScriptsExternos &/ Last.caption & " " & File.Name(TextBox1.Text) & "\n")

End

Public Sub menuPDFlibro_Click() 'generamos el PDF libro

  Dim metadatos As String

  metadatos = txtnombreArchivo.Text
  ' Verificar si el campo de metadatos existe
  If metadatos = "" Then
    Message.Error("Debe asegurar la construcción del archivo de metadatos", "Ok")
    Return
  End If

  ' Dim filePath As String
  Dim newFile As String
  Dim rutaFija As String
  Dim newLog As String

  ' filePath = File.Dir(TextBox1.Text) &/ "pdf"
  newFile = "pdf-" & BaseName & ".tex"
  rutaFija = File.Dir(TextBox1.Text) &/ "files"
  newLog = "gbTeX-" & BaseName & ".log"

  Borrar_Aux
  Wait 0.2

  TabPanel1.Index = 0

  ' exportamos los archivos bib, glo y meta
  Mod_Exportar.Exportar2BibTeX(TextBox1.Text)
  Mod_Exportar.Exportar2Glosario(TextBox1.Text)
  Mod_Exportar.Exportar2MetadatosPDF(TextBox1.Text)
  Wait 0.2

  'revisamos la carpeta pdf y borramos el archivo
  Mod_Funciones.ManagePdfFolder(TextBox1.Text)

  TerminalView1.Input("cat " & rutaFija &/ "general-book-pdf.tex" & " " & File.Name(TextBox1.Text) & " > " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("latexmk -l -f --interaction=nonstopmode -pdflatex=lualatex -pdflua " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("lualatex --interaction=nonstopmode " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("lualatex --interaction=nonstopmode " & newFile & "\n")
  Wait 0.2

  'ejecutamos en conteo del archivo LaTeX
  TerminalView1.Input("texcount -sub -sum -incbib -out=" & rutaFILES & "/gbTeX-" & BaseName & ".txt " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("rm -rf " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("mv " & File.Dir(TextBox1.Text) &/ "pdf-" & BaseName & ".pdf" & " " & File.Dir(TextBox1.Text) &/ "pdf/" & BaseName & ".pdf" & "\n")
  Wait 0.2

  'copiamos /files el archivo .log
  TerminalView1.Input("cat pdf-" & BaseName & ".log > " & rutaFILES & "/gbTeX-" & BaseName & ".log" & "\n")
  Wait 0.2

  'eliminamos los archivos auxiliares
  TerminalView1.Input("rm -rf " & File.Dir(TextBox1.Text) & "/artcap/*.aux" & "\n")
  Wait 0.2

  'generamos una vista con texlogsieve
  TerminalView1.Input("texlogsieve " & rutaFILES & "/gbTeX-" & BaseName & ".log > " & rutaFILES & "/gbTeXv-" & BaseName & ".log" & "\n")
  Wait 0.2

  TerminalView1.SetFocus()
  Borrar_Aux

End

Public Sub menuODt_DOCX_Click() 'convertimos a odt

  Dim metadatos As String

  metadatos = txtnombreArchivo.Text
  ' Verificar si el campo de metadatos existe
  If metadatos = "" Then
    Message.Error("Debe asegurar la construcción del archivo de metadatos", "Ok")
    Return
  End If

  Dim folder As String
  Dim newFile As String

  folder = File.Dir(TextBox1.Text) &/ "odt-docx"
  newFile = "odt-" & BaseName & ".tex"

  Borrar_Aux
  Wait 0.2

  ' exportamos los archivos
  Mod_Exportar.Exportar2BibTeX(TextBox1.Text)
  Mod_Exportar.Exportar2Glosario(TextBox1.Text)
  ' Mod_Exportar.Export2MetaDOCX(TextBox1.Text)
  Wait 0.2

  TabPanel1.Index = 0

  TerminalView1.Input("cat " & rutaFILES & "/general-odt.tex " & File.Name(TextBox1.Text) & " > " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("rm -rf odt-docx" & "\n")
  Wait 0.2

  TerminalView1.Input("mkdir odt-docx" & "\n")
  Wait 0.2

  ' esta instrucción no considera los metadatos
  TerminalView1.Input("make4ht -l -f odt -e " & rutaFILES & "/build.lua " & " -a Debug " & newFile & "\n" & "rm -rf " & newFile & "\n")
  Wait 0.2

  ' y esta s con los metadatos
  ' TerminalView1.Input("make4ht -l -f odt -e " & rutaFILES & "/build.lua -c " & rutaFILES & "/gbTeXmeta-" & BaseName & ".cfg -a Debug " & newFile & "\n")' & "rm -rf " & newFile & "\n")
  ' Wait 0.2

  'convertimos el odt a docx
  TerminalView1.Input("libreoffice --headless --convert-to docx" & " " & "*.odt" & "\n")
  Wait 0.2

  ' movemos los archivos al directorio odt-docx
  TerminalView1.Input("mv " & "odt-" & BaseName & ".docx" & " " & folder & "/" & BaseName & ".docx" & "\n")
  Wait 0.2

  TerminalView1.Input("mv " & "odt-" & BaseName & ".odt" & " " & folder & "/" & BaseName & ".odt" & "\n")' & "clear" & "\n")
  Wait 0.2

  ' TerminalView1.Input("rm -rf " & rutaFILES & "/gbTeXmeta-" & BaseName & ".cfg" & "\n")
  ' Wait 0.2

  TerminalView1.SetFocus()
  Borrar_Aux

End

