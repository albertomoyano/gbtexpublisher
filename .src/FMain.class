Public Sub Menu11_Click()'cerrar el programa

  Dim fecha As String

  fecha = Format(Date(), "dd-mm-yyyy") ' Obtener la fecha actual

  If Message.Question("¿Desea cerrar la aplicación?\n\nAl cerrar, esta acción realizará una copia de respaldo de la base de datos con el nombre <b>" & fecha & "-" & "db_tex.sqlite</b> y de <b>" & fecha & "-" & "conn_serv.sqlite</b>.", "Aceptar", "Cancelar") = 1 Then
    Conn.Close ' Cierra la conexión a la base de datos

    'hacemos una copia de respaldo de la base de datos
    Shell "cp " & rutaApp &/ "db_tex.sqlite" & " " & rutaAppR &/ fecha & "-" & "db_tex.sqlite"
    Wait 0.2
    Shell "cp " & rutaApp &/ "conn_serv.sqlite" & " " & rutaAppR &/ fecha & "-" & "conn_serv.sqlite"
    Wait 0.2

    'guardamos el último archivo abierto
    MS.SetLastListToSettings()
    Try pBash.Close
    Try fFile.Close
    Quit
  Else
    Stop Event
  Endif

End

' Evento Show del formulario
Public Sub Form_Show()
  ' Configura las coordenadas del formulario para ubicarlo en el margen superior derecho

  Me.Left = Screen.Width - Me.Width ' Establece la posición izquierda
  Me.Top = 0 ' Establece la posición superior

End

Public Sub menuEPUB_Click() 'convertimos a epub

  Dim folder As String
  Dim newFile As String

  folder = BaseName & "-epub"
  newFile = "epub-" & BaseName & ".tex"
  Borrar_Aux
  Wait 0.2

  ' exportamos los archivos bib, glo y meta
  Mod_Exportar.Exportar2BibTeX(TextBox1.Text)
  Mod_Exportar.Exportar2Glosario(TextBox1.Text)
  Mod_Exportar.Export2MetaEPUB(TextBox1.Text)
  Wait 0.2

  TerminalView1.Input("cat " & rutaFILES & "/general-epub.tex " & File.Name(TextBox1.Text) & " > " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("cat " & rutaFILES & "/configEPUB.cfg " & rutaFILES & "/gbTeXmeta-" & BaseName & ".tex" & " > " & rutaFILES & "/gbTeXmeta-" & BaseName & ".cfg" & "\n")
  Wait 0.2

  TerminalView1.Input("rm -rf epub" & "\n")
  Wait 0.2

  TerminalView1.Input("tex4ebook -l -f epub -e " & rutaFILES & "/build.lua -c " & rutaFILES & "/gbTeXmeta-" & BaseName & ".cfg -a Debug " & "epub-" & File.Name(TextBox1.Text) & "\n" & "rm -rf " & newFile & "\n")
  Wait 0.2

  TerminalView1.Input("mv epub-" & folder & " epub" & "\n" & "clear" & "\n")
  Wait 0.2

  ' TerminalView1.Input("rm -rf " & rutaFILES & "/gbTeXmeta-" & BaseName & ".cfg" & "\n")
  ' Wait 0.2

  TerminalView1.SetFocus()
  Borrar_Aux

End

