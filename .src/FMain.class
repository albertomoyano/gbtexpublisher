Public Sub menuBORRARtarea_Click()

  'Chequeamos primero que se haya seleccionado un elemento de la lista
  If VLista.Selected = False Then
    Message.Error("Debe elegir un ítem primero")
    Return
  Endif

  ' me conceto a la base de datos
