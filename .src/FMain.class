Public Sub btnGuardarIGUAL_Click()

  ' Escapa los caracteres especiales (comilla simple) en el título
  Dim tituloEscapado As String
  Dim idExistente As Boolean

  tituloEscapado = Replace(txtTITLE.Text, "'", "''")

  eliminarBlancosBIB()

  ' Verificar si el campo txtAUTHOR contiene un punto y coma (;)
  If InStr(txtAUTHOR.Text, ";") > 0 Then
    Message.Error("El campo Author no debe contener el caracter ';' (punto y coma).")
    Return ' Salir de la función si contiene alguno de estos caracteres
  Endif

  Busqueda = Conn.Exec("SELECT * FROM  bibtex WHERE title=&1 COLLATE NOCASE", tituloEscapado)

  If Busqueda.Count > 0 Then
    idExistente = False
  End If

  ' Ahora, utilizamos una estructura if para controlar el flujo
  If idExistente Then
    Message.Error("No se puede generar forzar grabar la entrada porque el ID ya existe.")
  Else
    If cbTYPEentrada.Text = "" Or cbLANGUAGE.Text = "" Then
      Message.Error("No ha seleccionado el tipo de entrada o el idioma.")
    Else

      ' Contenido = Conn.Create("bibtex")
      Contenido = Conn.Create("bibtex")

      guardarCampos()

      Contenido.Update
      Message.Info("Nueva entrada guardada.")

      Mostrar_ListaBIB ' Refrescamos la lista de entradas
      LimpiarCamposBIB() ' Limpiamos los campos

      btnGuardarCambios.Enabled = False
      btnGuardar.Enabled = False
      BtnNuevoBib.Enabled = True
      BtnEliminarBib.Enabled = False
      btnAgregarCitationKey.Enabled = False
      btnGuardarIGUAL.Enabled = False
    End If
  Endif

End

Public Function mostrarIguales()

  Dim Comando As String
  Dim rowIndex As Integer

  Comando = "SELECT * FROM bibtex WHERE title LIKE '%" & txtTITLE.Text & "%';"
  Busqueda = Conn.Exec(Comando)

  ' Limpia el Grid antes de mostrar los resultados de la búsqueda
  VListaBIB.Clear()

  ' Configura las columnas en el Grid
  VListaBIB.Columns.Count = 110

  ' Inicializa rowIndex a 0
  rowIndex = 0

  While (Busqueda.Available)
    ' Llena las celdas de la fila con los datos del resultado
    VListaBIB[rowIndex, 0].Text = Busqueda!id
    VListaBIB[rowIndex, 1].Text = Busqueda!tipoEntrada
    VListaBIB[rowIndex, 2].Text = Busqueda!citationKey
    VListaBIB[rowIndex, 3].Text = Busqueda!keywords
    VListaBIB[rowIndex, 4].Text = Busqueda!author
    VListaBIB[rowIndex, 5].Text = Busqueda!bookAuthor
    VListaBIB[rowIndex, 6].Text = Busqueda!editor
