Public Sub BtnEliminarBib_Click()

  'Chequeamos primero que se haya elegido una entrada
  If txtID.Text = "" Then
    Message.Info("Debe primero seleccionarse la entrada a borrar.")
    Return
  Endif

  If Message.Question("¿Desea borrar la entrada?", "Si", "No") = 1 Then
    Contenido = Conn.Exec("delete from bibtex where id=" & txtID.Text)
  Endif

  LimpiarCamposBIB() ' Limpiamos los campos
  VListaBIB.Clear()
  Mostrar_ListaBIB()

  BtnEliminarBib.Enabled = False
  btnGuardarCambios.Enabled = False
  btnAgregarCitationKey.Enabled = False
  btnGuardarIGUAL.Enabled = False

End

Public Sub BtnNuevoBib_Click()

  BtnNuevoBib.Enabled = False
  BtnEliminarBib.Enabled = False
  btnGuardar.Enabled = True
  btnGuardarCambios.Enabled = False
  btnAgregarCitationKey.Enabled = True
  ToolPanel1.Index = 0

  txtTMPbiblio.Clear 'limpiamos el campo temporal
  txtTMPbiblio.SetFocus()
  LimpiarCamposBIB()
  ObtenerNuevoId()

End

Public Sub ObtenerNuevoId()

  Dim Idn As Integer
  Dim MaxId As Variant

  MaxId = Conn.Exec("SELECT MAX(id) FROM bibtex LIMIT 1")

  If MaxId["MAX(id)"] = Null Then
    Idn = 0
  Else
    Idn = CInt(MaxId["MAX(id)"]) + 1
  Endif

  txtID.Text = Idn
  txtCLAVEbib.Text = "@" & Idn & "-"
  txtKEYWORDS.Text = "," & BaseName & ","

End

Public Sub btnGuardarCambios_Click()

  BtnNuevoBib.Enabled = True
  btnGuardar.Enabled = False
  btnGuardarCambios.Enabled = False
  btnGuardarIGUAL.Enabled = False
  BtnEliminarBib.Enabled = False
  btnAgregarCitationKey.Enabled = False

  'eliminamos blancos de inicio y final de cadena en los textbox
  eliminarBlancosBIB()

  Contenido = Conn.Edit("bibtex", "id=" & txtId.Text)
  guardarCampos()
  Contenido.Update
  Message.Info("Los cambios se guardaron con éxito.")

  LimpiarCamposBIB() ' Limpiamos los campos

End

Public Sub btnGuardar_Click()

  ' Escapa los caracteres especiales (comilla simple) en el título
  Dim tituloEscapado As String

  tituloEscapado = Replace(txtTITLE.Text, "'", "''")

  eliminarBlancosBIB()

  ' Verificar si el campo txtAUTHOR contiene un punto y coma (;)
  If InStr(txtAUTHOR.Text, ";") > 0 Then
    Message.Error("El campo Author no debe contener el caracter ';' (punto y coma).")
    Return ' Salir de la función si contiene alguno de estos caracteres
  Endif

  Busqueda = Conn.Exec("SELECT * FROM  bibtex WHERE title=&1 COLLATE NOCASE", tituloEscapado)

  ' Verificar si se encontraron resultados en la consulta
  If Busqueda.Count > 0 Then
    Message.Error("El título que desea agregar ya existe en la base de datos.")
    ' Cambiar la visibilidad del botón
    mostrarIguales()
    VListaBIB.ScrollY = 0
    ToolPanel1.Index = 1
    btnGuardar.Enabled = False
    btnGuardarIGUAL.Enabled = True
    Return ' Salir de la función si el título ya existe
  Endif

  If cbTYPEentrada.Text = "" Or cbLANGUAGE.Text = "" Then
    Message.Error("No ha seleccionado el tipo de entrada o idioma.")
  Else If cbTYPEentrada.Text = "thesis" And cbType.Text = "" Then
    Message.Error("No ha seleccionado el tipo de tesis.")
  Else

    Contenido = Conn.Create("bibtex")

    guardarCampos()

    Contenido.Update
    Message.Info("Nueva entrada guardada.")

    LimpiarCamposBIB() 'limpiamos los campos
    txtTMPbiblio.Clear 'limpiamos el campo temporal
    TotalEntradas()'actualizamos el contador de entradas
    btnGuardarCambios.Enabled = False
    btnGuardar.Enabled = False
    BtnNuevoBib.Enabled = True
    BtnEliminarBib.Enabled = False
    btnAgregarCitationKey.Enabled = False
    btnGuardarIGUAL.Enabled = False
  Endif

End

Public Sub BtnBuscarTituloReferencia_Click()'buscar título solamente

  txtBOOKTITLE.Text = ""

  Dim Comando As String
  Dim rowIndex As Integer

  If txtTITLE.Text = "" Then
    Message.Warning("Debe introducir un título a buscar.")
    Return
  Endif

  Comando = "SELECT * FROM bibtex WHERE title LIKE '%" & Replace(txtTITLE.Text, "'", "''") & "%';"
  Busqueda = Conn.Exec(Comando)

  ' Limpia el Grid antes de mostrar los resultados de la búsqueda
  VListaBIB.Clear()

  ' Si la búsqueda no arroja resultados
  If Busqueda.Count = 0 Then
    Message.Info("No se ha encontrado ningún resultado.")
    Return
  Endif

  ' Configura las columnas en el Grid
  VListaBIB.Columns.Count = 110

  ' Inicializa rowIndex a 0
  rowIndex = 0

  While (Busqueda.Available)
    ' Llena las celdas de la fila con los datos del resultado
    VListaBIB[rowIndex, 0].Text = Busqueda!id
    VListaBIB[rowIndex, 1].Text = Busqueda!tipoEntrada
    VListaBIB[rowIndex, 2].Text = Busqueda!citationKey
