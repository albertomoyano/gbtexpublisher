Public Sub BtnBuscarJournal_Click()

  Dim Comando As String
  Dim rowIndex As Integer

  If txtJOURNALTITLE.Text = "" Then
    Message.Warning("Debe introducir una revista a buscar.")
    Return
  Endif

  Comando = "SELECT * FROM bibtex WHERE journalTitle LIKE '%" & Replace(txtJOURNALTITLE.Text, "'", "''") & "%';"
