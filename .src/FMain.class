Public Sub btnAbrirPNG_Click()

  Dialog.Title = "Seleccionar archivo de tapa"
  Dialog.Filter = ["*.png", "Archivos de PNG"]
  Dialog.AutoExt = True
  Dialog.Path = rutaFILES
  Dialog.ShowHidden = False
  If Dialog.OpenFile() Then
    Return
  Else
    Dim rutaCover As String = File.Dir(Dialog.Path) &/ File.Name(Dialog.Path)
    txt49_imagentapa.Text = rutaCover
  Endif

End

Public Sub BtnNuevoMeta_Click()

  BtnNuevoMeta.Enabled = True
  btnGuardarMeta.Enabled = False
  btnGuardarCambiosMeta.Enabled = False

  Dim Idn As Integer

  ' Obtenemos el último ID y sumamos +1 para el nuevo registro
  Contenido = Conn.Exec("SELECT MAX(id) FROM metadatos LIMIT 1")

  ' Si no hay ninguna entrada entonces arrancamos desde 0
  If Contenido["MAX(id)"] = Null Then
    Idn = 0
  Else
    Idn = CInt(Contenido["MAX(id)"]) + 1
  Endif
  txtId.Text = Idn
  txtnombreArchivo.Text = BaseName & ".tex" 'colocamos el key con el nombre del archivo

  BtnNuevoMeta.Enabled = False
  btnGuardarMeta.Enabled = True
  btnGuardarCambiosMeta.Enabled = False

End

Public Sub btnGuardarMeta_Click()

  eliminarBlancosMETA

  Contenido = Conn.Create("metadatos")

  guardarCamposMETA

  Contenido.Update

  BtnNuevoMeta.Enabled = False
  btnGuardarMeta.Enabled = False
  btnGuardarCambiosMeta.Enabled = True

  Message.Info("Los cambios se guardaron con éxito.")

End

Public Function guardarCamposMETA() As Boolean

  ' Obtener el valor de txtDate
  Dim valorFecha As String

  valorFecha = txtDate.Text

  ' Verificar el formato usando una expresión regular
  If valorFecha Like "[0-9][0-9][0-9][0-9]-[0-9][0-9]" Then
    ' El formato es correcto
    Contenido!pdfdate_11 = txtDate.Text
    ' Puedes continuar con el resto del código para guardar
    Contenido!id = txtId.Text

    Contenido!nombreArchivo = txtnombreArchivo.Text
    Contenido!pdfxmp1_02 = txt02_pdfxmp1.Text
    Contenido!pdfxmp2_03 = txt03_pdfxmp2.Text
    Contenido!pdfxmp3_04 = txt04_pdfxmp3.Text
    Contenido!pdfauthor_05 = txt05_pdfauthor.Text
    Contenido!pdftitle_06 = txt06_pdftitle.Text
    Contenido!pdfsubject_07 = txtSubjet.Text
    Contenido!pdfkeywords_08 = txtKeywords.Text
    Contenido!pdfsubtitle_09 = txt09_pdfsubtitle.Text
    Contenido!pdfauthortitle_10 = txt10_pdfauthortitle.Text
    Contenido!pdfdate_11 = txtDate.Text
    Contenido!pdfcreationdate_12 = txtCreationDate.Text
    Contenido!pdfmoddate_13 = txtModDate.Text
    Contenido!pdfmetadate_14 = txtMetaDate.Text
    Contenido!pdfcopyright_15 = txt15_pdfcopyright.Text
    Contenido!pdflicenseurl_16 = txt16_pdflicenseurl.Text
    Contenido!pdfcaptionwriter_17 = txtCaptionWriter.Text
    Contenido!pdfcontactaddress_18 = txtContactAddress.Text
    Contenido!pdfcontactcity_19 = txtContactCity.Text
    Contenido!pdfcontactpostcode_20 = txtContactPostCode.Text
    Contenido!pdfcontactcountry_21 = txtContactCountry.Text
    Contenido!pdfcontactregion_22 = txtContactRegion.Text
    Contenido!pdfcontactphone_23 = txtContactPhone.Text
    Contenido!pdfcontactemail_24 = txtContactEmail.Text
    Contenido!pdfcontacturl_25 = txtContactURL.Text
    Contenido!pdfdocumentid_26 = txtDocumentId.Text
    Contenido!pdfpublication_27 = txtPublication.Text
    Contenido!pdfpublisher_28 = txtPublisher.Text
    Contenido!pdftype_29 = cmbType.Text
    Contenido!pdfpubtype_30 = cbPubType.Text
    Contenido!pdfvolumenum_31 = txtVolNum.Text
    Contenido!pdfissuenum_32 = txtIssueNum.Text
    Contenido!pdfpagerange_33 = txt33_pdfpagerange.Text
    Contenido!pdfbookedition_34 = txt34_pdfbookedition.Text
    Contenido!pdfisbn_35 = txt35_pdfisbn.Text
    Contenido!pdfissn_36 = txt36_pdfissn.Text
    Contenido!pdfeissn_37 = txt37_pdfeissn.Text
    Contenido!pdfpubstatus_38 = txt38_pdfpubstatus.Text
    Contenido!pdflang_39 = txtLang.Text
    Contenido!pdfmetalang_40 = txt40_pdfmetalang.Text
    Contenido!pdfbaseurl_41 = txtBaseURL.Text
    Contenido!pdfurl_42 = txt42_pdfurl.Text
    Contenido!pdfdoi_43 = txt43_pdfdoi.Text
    Contenido!pdfrendition_44 = cbPDFrendition.Text
    Contenido!pdfidentifier_45 = txtDocumentId.Text
    Contenido!pdfx_46 = cbPDFx.Text
    Contenido!pdfversionid_47 = txtVersionId.Text
    Contenido!abstract_48 = txt48_abstract.Text
    Contenido!imagentapa_49 = txt49_imagentapa.Text
    Contenido!pagetotal_50 = txt50_pagetotal.Text
    Contenido!relation_51 = txtCOLECCION.Text
    Contenido!direction_52 = txtDirection.Text
    Contenido!traductor_53 = txt53_traductor.Text
    Contenido!idiomaorig_54 = txt54_idiomaorig.Text
    Contenido!ilustrador_55 = txt55_ilustrador.Text
    Contenido!resumen_56 = txt56_resumen.Text
    Contenido!palabrasclave_57 = txt57_palabrasclave.Text
    Contenido!papertitletwo_58 = txt58_papertitletwo.Text
    Contenido!artrecibido_59 = txt59_artrecibido.Text
    Contenido!artaceptado_60 = txt60_artaceptado.Text
    Contenido!formato_61 = txtFORMATO.Text
    Contenido!source_69 = txt59_opt_source.Text
    Contenido!opt_72 = txt82_conferenceVisual.Text
    Contenido!genero_78 = txt78_genero.Text
    Contenido!conference_82 = txt82_conference.Text
    Contenido!bookTitle_84 = txt84_bookTitle.Text
    Contenido!doiRevista_85 = txt85_doiRevista.Text
    Contenido!notas_86 = txt86_annotation.Text
    Contenido!piehtml_87 = txt87_HTMLFirstPageBottom.Text
    Contenido!audience_88 = txt88_audiencia.Text
    Contenido!binding_89 = txt89_binding.Text

    Return True ' Indicar que el formato es válido
  Else
    ' El formato no es correcto, mostrar un mensaje de advertencia
    Message.Warning("El formato de Date no es válido. Debe ser en el formato '0000-00'.")
    txtDate.SetFocus
    ' Salir de la función o hacer cualquier otra acción que necesites
    Return False
  Endif

End

Public Function eliminarBlancosMETA()

  EliminarEspaciosAlInicioYFinal(txt05_pdfauthor)
  EliminarEspaciosAlInicioYFinal(txt06_pdftitle)

End

Public Sub btnGuardarCambiosMeta_Click()
  ' Eliminamos blancos de inicio y final de cadena en los textbox

  eliminarBlancosMETA

  Contenido = Conn.Edit("metadatos", "id=" & txtId.Text)

  ' Llamar a guardarCamposMETA y verificar si el formato de la fecha es válido
  If guardarCamposMETA() Then
    Contenido.Update
    Message.Info("Los cambios se guardaron con éxito.")
  Else
    Message.Warning("No se pudieron guardar los cambios debido a un formato de fecha no válido.")
  Endif

End

