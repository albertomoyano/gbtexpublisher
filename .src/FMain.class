  If Form_Notas.Visible Then
    Form_Notas.Close ' Cierra la ventana
  End If

  If Form_Logfile.Visible Then
    Form_Logfile.Close ' Cierra la ventana
  End If

  If Form_Contador.Visible Then
    Form_Contador.Close ' Cierra la ventana
  End If

  Mod_Funciones.CopiarArchivos(TextBox1.Text)

  'comienza metadatos
  Dim comando As String
