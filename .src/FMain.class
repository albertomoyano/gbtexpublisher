' Gambas class file

Private Conn As Connection
Private Contenido As Result
Private Busqueda As Result
Public pBash As Process
Public rutaFILES As String
Public rutaMEDIA As String
Public rutaCONTADOR As String
Public rutaCATALOGO As String
Public rutaARTCAP As String
Private rutaApp As String = User.Home &/ ".gbtexpublisher"
Private rutaAppR As String = User.Home &/ ".respaldogbTeX"
Private rutaScriptsExternos As String = User.Home &/ ".gbtexpublisher/ScriptsExternos"
Public rutaCORRECCIONES As String
Public Item_Seleccionado As Integer
Public fFile As File
Public sCurrentFilePath As String
Public rutaORIGINALES As String
Public rutaTAPA As String
Public BaseName As String
Private prevFiles As String[]' Variable para almacenar la lista de archivos anterior
