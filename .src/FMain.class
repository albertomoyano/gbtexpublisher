Public Sub menuGHPages_Click()

  Message.Info("Esta función genera una copia de las páginas estáticas en una carpeta docs, el proceso de <em>deploy</em> en GitHub Pages se debe hacer desde GitHub.", "Aceptar")

  'forzamos el borrado de las páginas estáticas
  Shell "rm -rf " & File.Dir(TextBox1.Text) &/ "docs"
  Wait 0.2

  'creamos el directorio de las páginas estáticas
  If Not Exist(File.Dir(TextBox1.Text) & "/docs") Then
    Mkdir File.Dir(TextBox1.Text) & "/docs"
  End If

  'copiamos los archivos
  TerminalView1.Input("cp -rv " & File.Dir(TextBox1.Text) & "/html5/*" & " " & File.Dir(TextBox1.Text) & "/docs/" & "\n" & "clear" & "\n")

End

