Public Sub menuRespaldoBDD_Click()

  Dim fecha As String
  Dim usuario As String = Trim(txtGIT.Text)
  Dim IdGitHub As String = "git@github.com:" & usuario & "/respaldogbTeX.git"

  TabPanel1.Index = 0

  ' Obtener la fecha actual
  fecha = Format(Date(), "dd-mm-yyyy")

  ' Verificar si el nombre de usuario está vacío
  If usuario = "" Then
    Message.Error("Debe indicar su nombre de usuario en GitHub", "Ok")
    Return
  End If

  'hacemos una copia de respaldo de la base de datos
  Shell "cp " & rutaApp &/ "db_tex.sqlite" & " " & rutaAppR &/ fecha & "-" & "db_tex.sqlite"
  Wait 0.2
  Conn.Close ' Cierra la conexión a la base de datos

  TerminalView1.Input("clear" & "\n")
  TerminalView1.Input("cd " & User.Home & "/.respaldogbTeX/" & "\n")
  TerminalView1.Input("git remote add origin " & IdGitHub & "\n") '
  TerminalView1.Input("git branch -M main" & "\n")
  TerminalView1.Input("git add ." & "\n")
  TerminalView1.Input("git commit -m '" & fecha & "'" & "\n")
  TerminalView1.Input("git push --set-upstream origin main" & "\n")
  TerminalView1.Input("cd " & File.Dir(TextBox1.Text) & "\n")
  TerminalView1.SetFocus()

  ' nos conectamos nuevamente a la base de datos
  Conn = Mod_Conn.conectar()

End

