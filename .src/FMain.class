Public Sub txtPAGES_Change()

  Dim curpos As Integer

  curpos = txtPAGES.pos

  Dim texto As String

  texto = txtPAGES.Text

  texto = Replace(texto, "  ", " ")
  texto = Replace(texto, "–", "-")
  texto = Replace(texto, "--", "-")
  texto = Replace(texto, " -", "-")
  texto = Replace(texto, "- ", "-")
  texto = Replace(texto, " a ", "-")

  txtPAGES.Text = texto

  ' Restaura la posición del cursor
  txtPAGES.pos = curpos

End

