Public Sub Mostrar_ListaGLO() 'Función que rellena el GridView

  Dim i As Integer

  ' me conecto a la base de datos
  Conn = Mod_Conn.conectar()

  VGridGLO.Clear()

  Contenido = Conn.Exec("select * from glosarios ORDER BY id DESC")

  'diseñamos el tableview
  VGridGLO.Columns.Count = 11
  VGridGLO.Header = True
  VGridGLO.Columns[0].Title = "ID"
  VGridGLO.Columns[0].Width = 60
  VGridGLO.Columns[1].Title = "Clave"
  VGridGLO.Columns[1].Width = 200
  VGridGLO.Columns[2].Title = "Tipo"
  VGridGLO.Columns[2].Width = 100
  VGridGLO.Columns[3].Title = ""
  VGridGLO.Columns[3].Width = 0
  VGridGLO.Columns[4].Title = "Nombre"
  VGridGLO.Columns[4].Width = 200
  VGridGLO.Columns[5].Title = ""
  VGridGLO.Columns[5].Width = 0
  VGridGLO.Columns[6].Title = "Primera vez"
  VGridGLO.Columns[6].Width = 800
  VGridGLO.Columns[7].Title = ""
  VGridGLO.Columns[7].Width = 0
  VGridGLO.Columns[8].Title = ""
  VGridGLO.Columns[8].Width = 0
  VGridGLO.Columns[9].Title = ""
  VGridGLO.Columns[9].Width = 0
  VGridGLO.Columns[10].Title = ""
  VGridGLO.Columns[10].Width = 0

  'ASIGNO LA CANTIDAD DE FILAS SEGUN LA CANTIDAD DE DATOS QUE EXISTEN
  VGridGLO.Rows.Count = Contenido.Count

  'recorremos el resutado de la consulta para mostrarlo
  For i = 0 To Contenido.Count - 1
    VGridGLO[i, 0].Text = Contenido!id
    VGridGLO[i, 1].Text = Contenido!key
    VGridGLO[i, 2].Text = Contenido!type
    VGridGLO[i, 3].Text = Contenido!archivo
    VGridGLO[i, 4].Text = Contenido!name
    VGridGLO[i, 5].Text = Contenido!description
    VGridGLO[i, 6].Text = Contenido!first
    VGridGLO[i, 7].Text = Contenido!text
    VGridGLO[i, 8].Text = Contenido!plural
    VGridGLO[i, 9].Text = Contenido!firstplural
    VGridGLO[i, 10].Text = Contenido!sort
    Contenido.MoveNext
  Next

  Dim RecordGLO As String
  Dim CountGLO As Integer
  Dim Record2GLO As String
  Dim Count2GLO As Integer
  Dim Contenido3 As Result
  Contenido = Conn.Exec("SELECT COUNT(*) FROM glosarios")
  RecordGLO = Contenido[0]
  CountGLO = RecordGLO
  Contenido3 = Conn.Exec("SELECT COUNT(*) FROM glosarios WHERE archivo LIKE '%" & "," & BaseName & "," & "%'")
  Record2GLO = Contenido3[0]
  Count2GLO = Record2GLO
  btnParcialGLO.Text = "(" & Count2GLO & ")"
  lblTotalesGLO.Text = "<b>Total de entradas en la base de datos: " & CountGLO & "</b>"

End

