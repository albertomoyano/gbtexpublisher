Public Sub menuGray_Click()

  Dim filemedia As String

  filemedia = File.Dir(TextBox1.Text) &/ "media/"

  'convertimos las imágenes color a 220dpi y a 11cm de ancho
  TerminalView1.Input("cd " & filemedia & "\n" & "magick mogrify -resize 953 -quality 99 *.*" & "\n")
  Wait 0.2

  'convertimos las imágenes a escala de grises
  TerminalView1.Input("magick convert -colorspace Gray * -set filename:base \"bn-%t\" \"%[filename:base].png\"" & "\n" & "cd .." & "\n" & "clear" & "\n")
  Wait 0.2

End

Public Sub menuAbrir_Click()

  Dialog.Title = "Seleccionar archivo"
  Dialog.Filter = ["*.tex", "Archivos de LaTeX"]
  Dialog.AutoExt = True
  Dialog.Path = User.Home
  If Dialog.OpenFile() Then
    Return
  Else
    TextBox1.Text = Dialog.Path
    sCurrentFilePath = TextBox1.Text
    DirViewRuta.Root = File.Dir(TextBox1.Text)
  Endif

  If Not MS.Matrix.Exist(Dialog.Path) Then
    If MS.Matrix.Count = MS.iLastNumber Then
      MS.Matrix.Remove(0)
      MS.ShortMatrix.Remove(0)
    End If
    MS.Matrix.Add(Dialog.Path)
    MS.ShortMatrix.Add(File.Name(Dialog.Path))
    UpdateMenu()
  End If

  rutaFILES = File.Dir(TextBox1.Text) & "/files"
  BaseName = File.BaseName(TextBox1.Text)
  ' rutaBIB = BaseName & ".bib"

  btnGuardarIGUAL.Enabled = False
  menuORTO.Enabled = True
