# Gambas Form File 3.0

{ Form Form
  Move(0,0,960,640)
  #Scaled = False
  Text = ("Aviso Legal")
  Resizable = False
  Arrangement = Arrange.Vertical
  Spacing = True
  Margin = True
  Padding = 4
  { HBox3 HBox
    Move(0,0,450,72)
    AutoResize = True
    Padding = 4
    { PictureBox1 PictureBox
      Move(0,0,72,72)
      Picture = Picture.Load("iconos/candado-abierto.svg")
      Stretch = True
      Alignment = Align.Center
      Mode = PictureBox.Fill
    }
  }
  { HBox2 HBox
    Move(18,117,900,36)
    { Label1 Label
      Move(9,0,738,36)
      Font = Font["Bold"]
      Expand = True
      Text = ("Aviso de Ausencia de Garantía y Condiciones de la Licencia LGPL-3.0")
    }
  }
  { TextArea1 TextArea
    Move(27,162,837,315)
    Background = Color.Background
    Expand = True
    Text = ("Este software se proporciona TAL CUAL, SIN GARANTÍA DE NINGÚN TIPO, expresa o implícita, incluyendo, pero no limitado a, las garantías de comerciabilidad, idoneidad para un propósito particular y no infracción. En ningún caso los autores o titulares de los derechos de autor serán responsables por cualquier reclamo, daños u otras responsabilidades, ya sea en una acción de contrato, agravio o de otra manera, derivados de, fuera de o en conexión con el software o el uso u otros negocios en el software.\n\nEste software es freesoftware y se distribuye bajo los términos de la Licencia Pública General Reducida de GNU versión 3 (LGPL-3.0). Puedes encontrar una copia de la licencia en el siguiente enlace: https://www.gnu.org/licenses/lgpl-3.0.html.\n\nEl código fuente de este software está disponible bajo solicitud. Si deseas acceder al código fuente para realizar cambios o contribuir, por favor ponte en contacto con el autor del software. El autor evaluará tu solicitud y, si es aprobada, te proporcionará acceso al código fuente según los términos de la LGPL-3.0.\n\nEste software utiliza bibliotecas de terceros bajo licencias compatibles con la LGPL. Para obtener más información sobre estas bibliotecas y sus licencias, consulta la documentación incluida en el repositorio o contacta al autor.\n\nPor favor, consulte la licencia para conocer los detalles completos de los derechos y limitaciones legales aplicables a este software.Este software es freesoftware y se distribuye bajo los términos de la Licencia Pública General Reducida de GNU versión 3 (LGPL-3.0). Puedes encontrar una copia de la licencia en el siguiente enlace: https://www.gnu.org/licenses/lgpl-3.0.html.\n\nEste programa utiliza las bibliotecas GTK, que están bajo la licencia LGPL. Puedes obtener las bibliotecas GTK desde https://www.gtk.org/\n")
    ReadOnly = True
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
  { HBox1 HBox
    Move(27,531,306,36)
    { Spring1 Spring
      Move(18,0,45,36)
    }
    { btnCerrar Button
      Move(81,0,198,36)
      Background = &H8BE06F
      NoTabFocus = True
      Text = ("Acepto los términos")
    }
  }
}
