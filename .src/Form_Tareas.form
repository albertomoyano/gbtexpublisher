# Gambas Form File 3.0

{ Form Form
  MoveScaled(0,0,68,29)
  Resizable = False
  Arrangement = Arrange.Vertical
  Padding = 4
  { HBox1 HBox
    MoveScaled(37,2,24,3.6)
    { Label1 Label
      MoveScaled(0,0,16,4)
      Alignment = Align.BottomNormal
      Text = (" Agregar a la lista")
    }
  }
  { HBox2 HBox
    MoveScaled(37,6,24,3.6)
    { txtAgregarLista TextBox
      MoveScaled(0,0,21,3.6)
      Expand = True
    }
  }
  { HBox3 HBox
    MoveScaled(37,10,24,3.6)
    { Label2 Label
      MoveScaled(0,0,11,4)
      Alignment = Align.BottomNormal
      Text = (" Descripción")
    }
  }
  { Panel1 Panel
    MoveScaled(33,15,28,8)
    Expand = True
    Arrangement = Arrange.Fill
    { txtAgregarDescripcion TextArea
      MoveScaled(0,0,22,7)
      Expand = True
      Wrap = True
    }
  }
  { HBox5 HBox
    MoveScaled(14,24,47,3.6)
    { Spring1 Spring
      MoveScaled(1,0,15,3.6)
    }
    { btnAgregar Button
      MoveScaled(18,0,16,3.6)
      Text = ("Listo")
      Picture = Picture["iconos/comp.svg"]
    }
    { btnCancelar Button
      MoveScaled(31,0,16,3.6)
      Text = ("Cancelar")
      Picture = Picture["iconos/salir.svg"]
    }
  }
}
