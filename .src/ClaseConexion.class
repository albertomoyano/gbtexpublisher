' Gambas class file

Public Function ConectarMySQL(Usuario As String, Clave As String, BD As String, Optional Tipo As String, Optional Host As String, Optional Puerto As String) As Connection

  Dim Con As New Connection

  Con.host = IIf(Host, Host, "Localhost")
  Con.port = IIf(Puerto, Puerto, "3306")
  Con.login = Usuario
  Con.Password = Clave
  Con.type = IIf(Tipo, Tipo, "mysql")
  Con.name = BD
  Con.Open
  Return Con

End

Public Function ConectarSQLite(Optional Type As String, Optional Host As String, Name As String) As Connection

  Dim Conn As New Connection

  Conn.Type = "sqlite"
  Conn.Host = User.Home &/ ".gbtexpublisher"
  Conn.Name = "db_tex.sqlite"
  Try Conn.Open()
  Return Conn

  If Error Then
    Conn = Null
    Message.Error("Error al conectar con la base de datos. Asegúrese de que el archivo con la base de datos se encuentre disponible. La misma debe encontrarse en " & User.Home &/ ".gbtexpublisher")
  Endif

End
