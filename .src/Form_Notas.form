# Gambas Form File 3.0

{ Form Form
  Move(0,0,950,640)
  #Scaled = False
  Text = ("Apuntes")
  Resizable = False
  Arrangement = Arrange.Vertical
  Padding = 4
  { HBox1 HBox
    Move(9,9,927,40)
    Padding = 1
    { tbNuevo Button
      Move(0,0,40,40)
      NoTabFocus = True
      ToolTip = ("Agregar entrada")
      Picture = Picture["iconos/+pestana.svg"]
    }
    { tbBorrar Button
      Move(36,0,40,40)
      NoTabFocus = True
      ToolTip = ("Eliminar entrada")
      Picture = Picture["iconos/borrar.svg"]
    }
    { btnGuardar Button
      Move(72,0,40,40)
      NoTabFocus = True
      ToolTip = ("Guardar entrada")
      Picture = Picture["iconos/guardar.svg"]
    }
    { btnGuardarMod Button
      Move(108,0,40,40)
      NoTabFocus = True
      ToolTip = ("Guardar cambios")
      Picture = Picture["iconos/guardarComo.svg"]
    }
    { !btnRefresh Button
      Move(144,0,40,40)
      #Public = True
      Visible = False
      NoTabFocus = True
      ToolTip = ("Refrescar datos")
      Picture = Picture["iconos/refrescar.svg"]
    }
    { BtnExportarDOCX Button
      Move(180,0,40,40)
      NoTabFocus = True
      ToolTip = ("Exportar la nota como archivo de texto plano")
      Picture = Picture["iconos/+nuevo.svg"]
    }
    { BtnExportarPDF Button
      Move(216,0,40,40)
      NoTabFocus = True
      ToolTip = ("Exportar la nota como archivo de texto plano")
      Picture = Picture["iconos/acroread.svg"]
    }
    { txtBuscar TextBox
      Move(252,0,290,40)
    }
    { BtnBuscar Button
      Move(693,0,40,40)
      NoTabFocus = True
      ToolTip = ("Buscar en toda la base de datos")
      Picture = Picture["iconos/search.svg"]
    }
    { Spring1 Spring
      Move(738,0,36,40)
    }
    { btnCerrar ToolButton
      Move(800,0,144,40)
      NoTabFocus = True
      ToolTip = ("Cerrar la ventana")
      Text = ("Cerrar")
      Picture = Picture["iconos/salir.svg"]
      Border = True
    }
  }
  { HBox8 HBox
    Move(10,80,765,40)
    Padding = 1
    { !txId TextBox
      Move(45,0,63,40)
      #Public = True
      Visible = False
      NoTabFocus = True
      Alignment = Align.Center
      ReadOnly = True
    }
    { !txFecha TextBox
      Move(117,0,126,40)
      #Public = True
      Visible = False
      NoTabFocus = True
      Alignment = Align.Center
      ReadOnly = True
    }
    { Label7 Label
      Move(387,0,63,40)
      NoTabFocus = True
      AutoResize = True
      Alignment = Align.Right
      Text = ("Asunto  ")
    }
    { !txAsunto TextBox
      Move(450,0,63,40)
      #Public = True
      NoTabFocus = True
      Expand = True
    }
  }
  { Splitter6 Splitter
    Move(90,160,468,423)
    Expand = True
    Arrangement = Arrange.Vertical
    Border = False
    { VLista TableView
      Move(70,120,153,81)
      Font = Font["-1"]
      Expand = True
      Mode = Select.Single
      ShowCursor = True
      Header = GridView.Horizontal
      ScrollBar = Scroll.Vertical
      Resizable = False
    }
    { !txContenido TextArea
      Move(90,310,180,54)
      #Public = True
      Font = Font["Monospace"]
      NoTabFocus = True
      Expand = True
      Wrap = True
      ScrollBar = Scroll.Vertical
    }
  }
}
