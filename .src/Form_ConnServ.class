' Gambas class file

Private Conn As Connection
Private Contenido As Result
Public rutaApp As String
Public rutaAppR As String
Public rutaScriptsExternos As String
Private vChk As String

Public Sub btnCancelar_Click()

  Shell "rm " & User.Home &/ "wget-log wget-log.*"
  Wait 0.1

  Conn.Close
  Me.Close

End

Public Sub Form_Open()

  vChk = GitVersion("https://raw.githubusercontent.com/albertomoyano/gbtexpublisher/master/.project")

  If Application.Version <> vChk Then
    Message.Info(("Está disponible una nueva versión") & ": " & vChk)
  Endif

  rutaApp = User.Home &/ ".gbtexpublisher"
  rutaScriptsExternos = rutaApp &/ "ScriptsExternos"
  rutaAppR = User.Home &/ ".respaldogbTeX"

  If Not Exist(rutaApp) Then
    Mkdir rutaApp
  End If

  If Not Exist(rutaScriptsExternos) Then
    Mkdir rutaScriptsExternos
  End If

  If Not Exist(rutaAppR) Then
    Mkdir rutaAppR
  End If

  If Not Exist(rutaApp &/ "db_tex.sqlite") Then
    Copy "./db_tex.sqlite" To rutaApp &/ "db_tex.sqlite"
  End If

  If Not Exist(rutaAppR &/ ".gitignore") Then
    Copy "./gitignore_BD" To rutaAppR &/ ".gitignore"
  End If

  If Not Exist(rutaApp &/ "conn_serv.sqlite") Then
    Copy "./conn_serv.sqlite" To rutaApp &/ "conn_serv.sqlite"
  End If

  If Not Exist(rutaApp & "/gitignore_github") Then
    Copy "./gitignore_github" To rutaApp & "/gitignore_github"
  End If

  If Not Exist(rutaApp & "/gitignore_gitlab") Then
    Copy "./gitignore_gitlab" To rutaApp & "/gitignore_gitlab"
  End If

  'scripts externos
  If Not Exist(rutaScriptsExternos &/ "Contador_global.py") Then
    Copy "./Contador_global.py" To rutaScriptsExternos &/ "Contador_global.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_llaves.py") Then
    Copy "./Control_de_llaves.py" To rutaScriptsExternos &/ "Control_de_llaves.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_signo_de_admiracion.py") Then
    Copy "./Control_de_signo_de_admiracion.py" To rutaScriptsExternos &/ "Control_de_signo_de_admiracion.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control-de_numeros.py") Then
    Copy "./Control-de_numeros.py" To rutaScriptsExternos &/ "Control-de_numeros.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_corchetes.py") Then
    Copy "./Control_de_corchetes.py" To rutaScriptsExternos &/ "Control_de_corchetes.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_parentesis.py") Then
    Copy "./Control_de_parentesis.py" To rutaScriptsExternos &/ "Control_de_parentesis.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_entorno.py") Then
    Copy "./Control_de_entorno.py" To rutaScriptsExternos &/ "Control_de_entorno.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Control_de_signo_de_pregunta.py") Then
    Copy "./Control_de_signo_de_pregunta.py" To rutaScriptsExternos &/ "Control_de_signo_de_pregunta.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Reemplazar_endash.py") Then
    Copy "./Reemplazar_endash.py" To rutaScriptsExternos &/ "Reemplazar_endash.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Buscar_posibles_parencite.py") Then
    Copy "./Buscar_posibles_parencite.py" To rutaScriptsExternos &/ "Buscar_posibles_parencite.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Reemplazos_ortotipográficos.py") Then
    Copy "./Reemplazos_ortotipográficos.py" To rutaScriptsExternos &/ "Reemplazos_ortotipográficos.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Limpieza_con_ExpReg.py") Then
    Copy "./Limpieza_con_ExpReg.py" To rutaScriptsExternos &/ "Limpieza_con_ExpReg.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Reemplazar_comillas.py") Then
    Copy "./Reemplazar_comillas.py" To rutaScriptsExternos &/ "Reemplazar_comillas.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Controlar_espacio_izquierda.py") Then
    Copy "./Controlar_espacio_izquierda.py" To rutaScriptsExternos &/ "Controlar_espacio_izquierda.py"
  End If

  If Not Exist(rutaScriptsExternos &/ "Buscar_palabra.py") Then
    Copy "./Buscar_palabra.py" To rutaScriptsExternos &/ "Buscar_palabra.py"
  End If

  'me concecto a la base de datos de inicio
  Conn = Mod_Conn.conectar2()
  Mostrar_Lista()

  tblConnServ.Columns.Count = 3
  tblConnServ.Header = True
  tblConnServ.Columns[0].Title = "id"
  tblConnServ.Columns[0].Width = 0
  tblConnServ.Columns[1].Title = "IP"
  tblConnServ.Columns[1].Width = 295
  tblConnServ.Columns[2].Title = "Nombre"
  tblConnServ.Columns[2].Width = 295

  BtnEliminarBBDD.Visible = False
  btnGuardar.Visible = False
  btnGuardarMod.Visible = False
  txtIP.Visible = False
  txtNOMBRE.Visible = False
  txtUSUARIO.Visible = False
  txtCLAVE.Visible = False

End

Public Sub BtnNuevaBBDD_Click()

  txtUSUARIO.Visible = False
  txtCLAVE.Visible = False
  txtIP.Visible = True
  txtNOMBRE.Visible = True
  btnGuardar.Visible = True
  BtnNuevaBBDD.Visible = False
  BtnEliminarBBDD.Visible = False
  btnGuardarMod.Visible = False
  txtIP.SetFocus()

  Dim Idn As Integer

  LimpiarCampos  'Limpiamos todos los campos

  'Obtenemos el último ID y sumamos +1 para el nuevo registro
  Contenido = Conn.Exec("SELECT MAX(id) FROM servidores LIMIT 1")

  ' Si no hay ninguna entrada entonces arrancamos desde 0
  If Contenido["MAX(id)"] = Null Then
    Idn = 0
  Else
    Idn = CInt(Contenido["MAX(id)"]) + 1
  Endif
  txtID.Text = Idn
  Mostrar_Lista

End

Public Sub btnLocal_Click()

  Shell "rm " & User.Home &/ "wget-log wget-log.*"
  Wait 0.1

  Me.Close
  FMain.Show()
  ' me conceto a la base de datos
  Conn = Mod_Conn.conectar()

End

Public Sub btnLegales_Click()

  Form_Legales.ShowModal()

End

Public Function GitVersion(raw As String) As String 'Función para chequear si hay versiones nuevas

  Dim s As String
  Dim stx As String[]
  Dim r As String
  Dim v As String

  v = ""
  If Exist("/tmp/project.txt") Then
    Shell "rm /tmp/project.txt" Wait
  Endif

  Shell "wget -O '/tmp/project.txt' '" & raw & "'" Wait
  If Exist("/tmp/project.txt") Then
    s = File.Load("/tmp/project.txt")
    stx = Split(s, "\n")
    For Each r In stx
      If InStr(r, "Version=") Then
        If Split(r, "=")[0] = "Version" Then
          v = Split(r, "=")[1]
          Break
        Endif
      Endif
    Next
  Endif
  Return v

End

Public Function LimpiarCampos()

  'Limpiamos los campos
  txtID.Text = ""
  txtNOMBRE.Text = ""
  txtIP.Text = ""
  txtUSUARIO.Text = ""
  txtCLAVE.Text = ""

End

Public Sub Mostrar_Lista() 'Función que rellena con el title el List View

  Dim i As Integer

  tblConnServ.Clear()

  Contenido = Conn.Exec("select * from servidores")

  'diseñamos el tableview
  tblConnServ.Columns.Count = 3
  tblConnServ.Header = True
  tblConnServ.Columns[0].Title = "ID"
  tblConnServ.Columns[0].Width = 0
  tblConnServ.Columns[1].Title = "IP"
  tblConnServ.Columns[1].Width = 295
  tblConnServ.Columns[2].Title = "Nombre"
  tblConnServ.Columns[2].Width = 295

  'ASIGNO LA CANTIDAD DE FILAS SEGUN LA CANTIDAD DE DATOS QUE EXISTEN
  tblConnServ.Rows.Count = Contenido.Count

  'recorremos el resutado de la consulta para mostrarlo
  For i = 0 To Contenido.Count - 1
    tblConnServ[i, 0].Text = Contenido!id
    tblConnServ[i, 1].Text = Contenido!ip
    tblConnServ[i, 2].Text = Contenido!nombre

    Contenido.MoveNext
  Next

End

Public Sub Form_Close()

  Shell "rm " & User.Home &/ "wget-log wget-log.*"
  Wait 0.1

  Conn.Close
  Me.Close

End

Public Sub btnGuardar_Click()

  Contenido = Conn.Create("servidores")

  guardarCampos

  Contenido.Update
  Message.Info("Nuevo servidor guardado.")

  Mostrar_Lista ' Refrescamos la lista de entradas
  LimpiarCampos ' Limpiamos los campos

  txtIP.Visible = False
  txtNOMBRE.Visible = False
  txtUSUARIO.Visible = False
  txtCLAVE.Visible = False
  btnGuardar.Visible = False
  BtnNuevaBBDD.Visible = True

End

Public Function guardarCampos()

  Contenido!id = txtID.Text
  Contenido!ip = txtIP.Text
  Contenido!nombre = txtNOMBRE.Text

End

Public Sub tblConnServ_RowClick(Row As Integer)

  btnGuardarMod.visible = True
  BtnEliminarBBDD.Visible = True

  txtNOMBRE.Visible = True
  txtIP.Visible = True
  txtUSUARIO.Visible = True
  txtCLAVE.Visible = True

  txtID.Text = tblConnServ[Row, 0].Text
  txtIP.Text = tblConnServ[Row, 1].Text
  txtNOMBRE.Text = tblConnServ[Row, 2].Text

End

Public Sub BtnEliminarBBDD_Click()

  'Chequeamos primero que se haya elegido una entrada
  If txtID.Text = "" Then
    Message.Info("Debe primero seleccionar un servidor a borrar.")
    Return
  Endif

  If Message.Question("¿Desea borrar el servidor de la base de datos?", "Si", "No") = 1 Then
    Contenido = Conn.Exec("delete from servidores where id=" & txtID.Text)
  Endif

  LimpiarCampos  'Limpiamos los campos

  tblConnServ.Clear
  Mostrar_Lista

  BtnEliminarBBDD.Visible = False
  btnGuardarMod.Visible = False
  BtnNuevaBBDD.Visible = True
  txtIP.Visible = False
  txtNOMBRE.Visible = False
  txtUSUARIO.Visible = False
  txtCLAVE.Visible = False

End

Public Sub btnGuardarMod_Click()

  Contenido = Conn.Edit("servidores", "id=" & txtID.Text)
  guardarCampos
  Contenido.Update
  Message.Info("Los cambios se guardaron con éxito.")

  Mostrar_Lista
  LimpiarCampos 'limpiar campos

  txtIP.Visible = False
  txtNOMBRE.Visible = False
  txtUSUARIO.Visible = False
  txtCLAVE.Visible = False
  btnGuardar.Visible = False
  BtnNuevaBBDD.Visible = True

End

Public Sub btnRemoto_Click()

  Message.Info("Función en desarrollo", "Aceptar")

End
