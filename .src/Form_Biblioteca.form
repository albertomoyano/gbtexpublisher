# Gambas Form File 3.0

{ Form Form
  Move(0,0,960,640)
  #Scaled = False
  Text = ("Biblioteca de trabajos")
  Icon = Picture["iconos/basededatos.svg"]
  Resizable = False
  Arrangement = Arrange.Vertical
  Spacing = True
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(0,0,927,36)
    { tbNuevo Button
      Move(0,0,36,36)
      NoTabFocus = True
      ToolTip = ("Agregar entrada")
      Picture = Picture["iconos/+nuevo.svg"]
    }
    { tbBorrar Button
      Move(36,0,36,36)
      NoTabFocus = True
      ToolTip = ("Eliminar entrada")
      Picture = Picture["iconos/borrar.svg"]
    }
    { btnGuardar Button
      Move(72,0,36,36)
      NoTabFocus = True
      ToolTip = ("Guardar entrada")
      Picture = Picture["iconos/guardar.svg"]
    }
    { btnGuardarMod Button
      Move(108,0,36,36)
      NoTabFocus = True
      ToolTip = ("Guardar cambios")
      Picture = Picture["iconos/guardarComo.svg"]
    }
    { !btnRefresh Button
      Move(144,0,36,36)
      #Public = True
      NoTabFocus = True
      ToolTip = ("Refrescar datos")
      Picture = Picture["iconos/refrescar.svg"]
    }
    { Spring1 Spring
      Move(450,0,234,36)
    }
    { btnCerrar ToolButton
      Move(702,0,160,36)
      Background = &HE00000
      Foreground = Color.White
      NoTabFocus = True
      ToolTip = ("Cerrar la ventana")
      Text = ("Cerrar")
      Border = True
    }
  }
  { HBox8 HBox
