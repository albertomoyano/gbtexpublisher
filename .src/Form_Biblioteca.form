      Move(270,0,144,36)
      NoTabFocus = True
      Alignment = Align.Right
      Text = ("Archivo .tex  ")
    }
    { BtnBuscar Button
      Move(468,0,36,36)
      NoTabFocus = True
      ToolTip = ("Buscar en toda la base de datos")
      Picture = Picture["iconos/search.svg"]
    }
    { !txAsunto TextBox
      Move(585,0,63,36)
      #Public = True
      NoTabFocus = True
      Expand = True
    }
  }
  { HBox2 HBox
    Move(0,99,765,36)
