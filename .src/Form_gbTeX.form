# Gambas Form File 3.0

{ Form Form
  Move(0,0,680,490)
  #Scaled = False
  Expand = True
  Text = ("Acerca de gbTeXpublisher")
  Resizable = False
  Arrangement = Arrange.Vertical
  Padding = 4
  { HBox2 HBox
    Move(0,0,450,72)
    AutoResize = True
    Padding = 4
    { PictureBox1 PictureBox
      Move(0,0,72,72)
      Picture = Picture.Load("iconos/icono-gbtex.png")
      Stretch = True
      Alignment = Align.Center
      Mode = PictureBox.Fill
    }
  }
  { TextArea1 TextArea
    Move(20,170,495,216)
    Background = Color.Background
    Expand = True
    Text = ("gbTeXpublisher esta programado para ser utilizado con las librerías Qt, si usted utiliza GTK es posible que tenga una interfaz gráfica con errores.\n\ngbTeXpublisher es una aplicación que permite gestionar los procesos de producción editorial basados en el lenguaje LaTeX.\n\nEntre sus principales características observamos:\n\n- Modelo de trabajo basado en un solo origen\n- Manejo de referencias bibliográficas\n- Integración con GitHub y GitLab\n- Capacidad de personalización de las salidas")
    Alignment = Align.Left
    ReadOnly = True
    Wrap = True
    ScrollBar = Scroll.Vertical
  }
  { HBox1 HBox
    Move(20,430,567,36)
    { Spring1 Spring
      Move(36,0,36,36)
    }
    { btnCerrar Button
      Move(360,0,144,36)
      Text = ("Cerrar")
      Picture = Picture["iconos/salir.svg"]
    }
  }
}
