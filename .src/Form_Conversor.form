# Gambas Form File 3.0

{ Form Form
  Move(0,0,950,207)
  #Scaled = False
  #Translate = False
  Text = "Conversión de archivo a formato LaTeX"
  Resizable = False
  Arrangement = Arrange.Vertical
  AutoResize = True
  Spacing = True
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(0,0,942,40)
    Padding = 2
    { Label3 Label
      Move(0,0,72,36)
      NoTabFocus = True
      Alignment = Align.Right
    }
    { RadioButton1 RadioButton
      Move(108,0,198,36)
      AutoResize = True
      Text = ("Archivo DOCX (Pandoc) ")
      Value = True
    }
    { RadioButton2 RadioButton
      Move(315,0,234,36)
      AutoResize = True
      Text = ("Archivo DOCX (docx2tex) ")
    }
    { RadioButton3 RadioButton
      Move(558,0,243,36)
      AutoResize = True
      Text = ("Archivo RTF (Pandoc) ")
    }
  }
  { HBox2 HBox
    Move(10,40,800,40)
    NoTabFocus = True
    Padding = 2
    { Label1 Label
      Move(9,0,72,40)
      NoTabFocus = True
      Alignment = Align.Right
      Text = ("Origen ")
    }
    { txtORIGEN TextBox
      Move(126,0,216,40)
      #Translate = False
      Foreground = Color.Blue
      NoTabFocus = True
      Expand = True
      ReadOnly = True
      Placeholder = "Seleccione un archivo word con extensión docx"
    }
    { btnBuscar Button
      Move(351,0,160,40)
      NoTabFocus = True
      Text = ("Buscar")
      Picture = Picture["iconos/document.svg"]
    }
  }
  { HBox3 HBox
    Move(0,80,800,40)
    NoTabFocus = True
    Padding = 2
    { Label2 Label
      Move(0,0,72,40)
      NoTabFocus = True
      Alignment = Align.Right
      Text = ("Destino ")
    }
    { txtDESTINO TextBox
      Move(126,0,216,40)
      NoTabFocus = True
      Expand = True
      Placeholder = ("caracteres permitidos: 0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ")
    }
    { btnCONVERTIR Button
      Move(351,0,160,40)
      Enabled = False
      NoTabFocus = True
      Text = ("Convertir")
      Picture = Picture["iconos/conversor.svg"]
    }
  }
  { HBox7 HBox
    Move(0,120,942,40)
    Padding = 2
    { lblMENSAJE Label
      Move(0,0,144,40)
