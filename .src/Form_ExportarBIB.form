# Gambas Form File 3.0

{ Form Form
  Move(0,0,1024,208)
  #Scaled = False
  Expand = True
  Text = ("Exportar referencias bibliográficas")
  Resizable = False
  Arrangement = Arrange.Vertical
  Margin = True
  Padding = 4
  { HBox1 HBox
    Move(0,9,950,40)
    Padding = 2
    { TextLabel1 TextLabel
      Move(63,0,108,36)
      Padding = 4
      Text = ("Destino  ")
      Alignment = Align.Right
    }
    { !txtdestino TextBox
      Move(216,0,144,32)
      #Public = True
      Foreground = Color.DarkBlue
      Expand = True
      ReadOnly = True
    }
    { btnDestino Button
      Move(477,0,36,36)
      Picture = Picture["iconos/document-orange.svg"]
    }
  }
  { HBox2 HBox
    Move(0,45,950,40)
    Padding = 2
    { Label1 Label
      Move(225,0,468,32)
      Font = Font["Bold"]
      Expand = True
      Alignment = Align.Center
      Text = ("Asegurese de escribir correctamente el nombre del filtro de exportación")
    }
  }
  { HBox3 HBox
    Move(-45,81,950,40)
    Padding = 2
    { TextLabel4 TextLabel
      Move(63,0,108,36)
      Padding = 4
      Text = ("Filtro  ")
      Alignment = Align.Right
    }
    { txtFiltro TextBox
      Move(216,0,144,36)
      Expand = True
    }
    { TextLabel2 TextLabel
      Move(369,0,144,36)
      Padding = 4
      Text = ("  Exportar como  ")
      Alignment = Align.Right
    }
    { txtNombre TextBox
      Move(513,0,198,36)
      Placeholder = ("Nombre sin la extensión")
    }
  }
  { HBox4 HBox
    Move(0,117,950,40)
    Padding = 2
    { Label2 Label
      Move(225,0,468,36)
      Font = Font["Bold,Italic"]
      Expand = True
      Alignment = Align.Center
    }
  }
  { HBox14 HBox
    Move(0,153,950,40)
    Padding = 2
    { Spring1 Spring
      Move(63,0,90,32)
    }
    { btnExportarBIB Button
      Move(441,0,160,36)
      Text = ("Exportar")
      Picture = Picture["iconos/exportar.svg"]
    }
    { btnCancelar Button
      Move(612,0,160,36)
      Text = ("Cerrar")
      Picture = Picture["iconos/salir.svg"]
    }
  }
}
