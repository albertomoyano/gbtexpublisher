' Gambas class file

Private conector As Connection
Private Contenido As Result
Private Busqueda As Result

Public Sub Form_Open()

  Splitter1.Layout = [1, 5]
  ' Crear una nueva conexión
  conector = New Connection

  ' Configurar los parámetros de conexión
  conector.Type = "sqlite"
  conector.Host = User.Home &/ ".gbtexpublisher"
  conector.Name = "conn_serv.sqlite"

  ' Intentar abrir la conexión
  Try conector.Open()

  If Error Then
    conector = Null
    Message.Error("Error al conectar con la base de datos. Asegúrese de que el archivo con la base de datos se encuentre disponible. La misma debe encontrarse en " & User.Home &/ ".gbtexpublisher")
  Else

    Dim filePath As String
    Dim NombreArchivo As String

    ' Construir el nombre del archivo PDF
    NombreArchivo = File.BaseName(FMain.TextBox1.Text) & ".pdf"

    filePath = File.Dir(FMain.TextBox1.Text) & "/pdf/" & NombreArchivo

    If File.RealPath(filePath) <> "" Then
      ' Si el archivo existe, continuar con la apertura del formulario
      Form_OTimprenta.Title = "Orden de taller para el archivo " & NombreArchivo
      'aquí van las funciones del formulario
      '1) validar que sea un tipoDocumento Libro
      '2) llenar los textbox básicos
      '
    Else
      Message.Error("El archivo <b>" & NombreArchivo & "</b> no existe.")
      Me.Close
    Endif

  Endif

End

Public Sub btnSalirOT_Click()

  ' Cerrar la conexión si está abierta
  If conector Then
    conector.Close()
    conector = Null
  Endif

  Me.Close()

End

Public Sub Button1_Click()

End

Public Sub Splitter1_Resize()

  Splitter1.Layout = [1, 5]

End
