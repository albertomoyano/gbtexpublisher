' Gambas class file

Private Conn As Connection

Public Sub btnBuscar_Click()

  Dialog.Title = "Seleccionar archivo con bibliografía"
  Dialog.Filter = ["*.bib", "Archivos bibtex"]
  Dialog.AutoExt = True
  Dialog.Path = User.Home
  If Dialog.OpenFile() Then
    Return
  Else
    txtOrigenBIB.Text = Dialog.Path
  Endif

Catch
  Message.Error("No se pudo abrir el archivo")

End

Public Sub Form_Close()

  Conn.Close
  Me.Close()

End

Public Sub btnSalir_Click()

  Conn.Close
  Me.Close()

End

Public Sub btnConvertirCSV_Click()

  Dim rutaApp As String
  Dim origenBib As String

  rutaApp = User.Home & "/.gbtexpublisher"
  origenBib = txtOrigenBIB.Text

  Shell "python " & rutaApp &/ "Convertir_bib_a_csv.py" & " " & origenBib & " " & File.Dir(txtOrigenBIB.Text) &/ File.BaseName(txtOrigenBIB.Text) & ".csv"
  Wait 0.2

  txtOrigenCSV.Text = File.Dir(txtOrigenBIB.Text) &/ File.BaseName(txtOrigenBIB.Text) & ".csv"
  Label1.Visible = True
  btnImportar.Enabled = True

End

Public Sub btnImportar_Click()

  Dim rutaApp As String
  Dim origenCSV As String

  rutaApp = User.Home & "/.gbtexpublisher"
  origenCSV = txtOrigenCSV.Text

  Shell "python " & rutaApp &/ "Importar_CSV.py" & " " & origenCSV & " " & rutaApp &/ "db_tex.sqlite"
  Wait 0.2

  Label1.Text = "La importación se realizó con éxito."
  txtOrigenCSV.Clear
  txtOrigenBIB.Clear

End

Public Sub Form_Open()

  ' me conceto a la base de datos
  Conn = Mod_Conn.conectar()
  btnImportar.Enabled = False

End
