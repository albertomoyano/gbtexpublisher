' Gambas class file

Public Sub btnCerrar_Click()

  Me.Close

End

Public Sub Form_Open()

  Dim buildLUA As String
  Dim configEPUB As String
  Dim configHTML As String
  Dim configJATS As String
  Dim fileContent1 As String
  Dim fileContent3 As String
  Dim fileContent4 As String
  Dim fileContent5 As String

  Form_CFG.Title = "Configuración de archivos de compilación para " & FMain.BaseName & ".tex"

  buildLUA = FMain.rutaFILES &/ "build.lua"
  configEPUB = FMain.rutaFILES &/ "configEPUB.cfg"
  configHTML = FMain.rutaFILES &/ "configHTML.cfg"
  configJATS = FMain.rutaFILES &/ "configJATS.cfg"

  fileContent1 = File.Load(buildLUA)
  fileContent3 = File.Load(configEPUB)
  fileContent4 = File.Load(configHTML)
  fileContent5 = File.Load(configJATS)

  txtLUA.Text = fileContent1
  txtEPUB.Text = fileContent3
  txtHTML.Text = fileContent4
  txtJATS.Text = fileContent5

End

Public Sub btnGuardarConfig_Click()' guardamos los cambios

  Dim buildLUA As String
  Dim configEPUB As String
  Dim configHTML As String
  Dim configJATS As String

  buildLUA = FMain.rutaFILES &/ "build.lua"
  configEPUB = FMain.rutaFILES &/ "configEPUB.cfg"
  configHTML = FMain.rutaFILES &/ "configHTML.cfg"
  configJATS = FMain.rutaFILES &/ "configJATS.cfg"

  File.Save(buildLUA, txtLUA.Text)
  File.Save(configEPUB, txtEPUB.Text)
  File.Save(configHTML, txtHTML.Text)
  File.Save(configJATS, txtJATS.Text)

  Message.Info("Los cambios se han guardado correctamente.")

End
